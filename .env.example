# Required for live runs. Omit when running with --dry-run.
DISCORD_WEBHOOK_URL=

# Implied-probability gap threshold in percentage points. Default 3.
# Below ~3% you're usually just looking at margin/vig differences, not real edge.
ALERT_THRESHOLD_PCT=3

# How many top gaps to push per run. Default 10.
ALERT_TOP_N=10
