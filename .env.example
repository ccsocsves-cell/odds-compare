# Required for live runs. Omit when running with --dry-run.
DISCORD_WEBHOOK_URL=

# Minimum guaranteed profit (% of total stake) for an arb alert. Default 0.5.
ALERT_THRESHOLD_PCT=0.5

# How many top arbs to push per run. Default 10.
ALERT_TOP_N=10

# Bankroll unit used for the stake split shown in alerts. Default 100.
STAKE_BASE=100

# Re-alert a previously posted arb only when its profit improved by more
# than this many percentage points. Default 0.3.
DEDUP_IMPROVE_PCT=0.3

# Where the cross-run dedup state lives. Default data/seen-arbs.json.
#SEEN_ARBS_PATH=data/seen-arbs.json

# Set to 0 to skip the boabet Playwright scraper (headed Chromium, ~1 min).
ENABLE_BOABET=1

# Force a Discord status post even when no arbs were found (daily heartbeat).
HEARTBEAT=0

# 22bet politeness knobs. The mirror host is auto-discovered from the
# 22bet.com redirect; override only when both entry and fallback are dead.
#BET22_BASE=https://22bt104.info/service-api/LineFeed
BET22_MAX_CHAMPS=25
BET22_MAX_GAMES=80
#BET22_GAP_MS=250

# Save raw API payloads to data/samples/ for parser debugging.
SAVE_SAMPLES=0
